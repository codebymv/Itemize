# =============================================
# Itemize frontend (Vite) — environment variables
# =============================================
# Copy to `.env`. All VITE_* keys are exposed to the browser bundle.
# =============================================

# ---------- API (required for real backend) ----------
# Local backend (matches backend/README default port).
VITE_API_URL=http://localhost:3001

# Contact list/detail reads remain on REST unless explicitly enabled.
# Point this at the full NestJS GraphQL endpoint before switching the flag.
VITE_GRAPHQL_URL=http://localhost:3100/graphql
VITE_CONTACT_READS_GRAPHQL=false
# Contact create/update/delete remain on REST unless separately enabled.
VITE_CONTACT_MUTATIONS_GRAPHQL=false
# Contact bulk update/delete remain on REST unless separately enabled.
VITE_CONTACT_BULK_MUTATIONS_GRAPHQL=false
# Contact timeline reads/writes remain on REST unless separately enabled.
VITE_CONTACT_ACTIVITIES_GRAPHQL=false
# Contact-linked lists/notes/whiteboards remain on REST unless separately enabled.
VITE_CONTACT_CONTENT_GRAPHQL=false
VITE_DEAL_READS_GRAPHQL=false
VITE_DEAL_MUTATIONS_GRAPHQL=false
# Authenticated booking reads, cancellation, and create/reschedule have three
# independent default-off rollback boundaries. Anonymous protocols remain REST.
VITE_BOOKING_READS_GRAPHQL=false
VITE_BOOKING_MUTATIONS_GRAPHQL=false
VITE_BOOKING_SCHEDULING_MUTATIONS_GRAPHQL=false
# Invoice product catalog reads and writes have separate rollback boundaries.
VITE_PRODUCT_READS_GRAPHQL=false
VITE_PRODUCT_MUTATIONS_GRAPHQL=false
# Invoice sender/business profile reads and CRUD writes. Logo bytes remain HTTP.
VITE_INVOICE_BUSINESS_READS_GRAPHQL=false
VITE_INVOICE_BUSINESS_MUTATIONS_GRAPHQL=false
# Core invoice list/detail and CRUD have separate rollback boundaries.
VITE_INVOICE_READS_GRAPHQL=false
VITE_INVOICE_MUTATIONS_GRAPHQL=false
# Authenticated analytics reads switch independently; every flag is default-off.
VITE_DASHBOARD_ANALYTICS_GRAPHQL=false
VITE_CONTACT_TRENDS_GRAPHQL=false
VITE_DEAL_PERFORMANCE_GRAPHQL=false
VITE_BOOKING_ANALYTICS_GRAPHQL=false
VITE_COMMUNICATION_STATS_GRAPHQL=false
VITE_WORKFLOW_PERFORMANCE_GRAPHQL=false
VITE_EMAIL_TEMPLATE_READS_GRAPHQL=false
VITE_EMAIL_TEMPLATE_MUTATIONS_GRAPHQL=false
VITE_SMS_TEMPLATE_READS_GRAPHQL=false
VITE_SMS_TEMPLATE_MUTATIONS_GRAPHQL=false
VITE_CAMPAIGN_READS_GRAPHQL=false
VITE_CAMPAIGN_MUTATIONS_GRAPHQL=false
VITE_CAMPAIGN_AUDIENCE_PREVIEW_GRAPHQL=false
VITE_CAMPAIGN_RECIPIENT_READS_GRAPHQL=false
VITE_CAMPAIGN_TEST_SEND_GRAPHQL=false
# Invoice preview, delivery, and standalone Stripe-link operations switch independently.
VITE_INVOICE_EMAIL_PREVIEW_GRAPHQL=false
VITE_INVOICE_SEND_GRAPHQL=false
VITE_INVOICE_PAYMENT_LINK_GRAPHQL=false
# Estimate list/detail, CRUD, and conversion have separate rollback boundaries.
VITE_ESTIMATE_READS_GRAPHQL=false
VITE_ESTIMATE_MUTATIONS_GRAPHQL=false
VITE_ESTIMATE_CONVERSION_GRAPHQL=false
VITE_ESTIMATE_SEND_GRAPHQL=false
# Recurring-template reads, CRUD, pause/resume, cloning, and generation have independent rollback boundaries.
VITE_RECURRING_INVOICE_READS_GRAPHQL=false
VITE_RECURRING_INVOICE_MUTATIONS_GRAPHQL=false
VITE_RECURRING_INVOICE_LIFECYCLE_GRAPHQL=false
VITE_RECURRING_INVOICE_CLONE_GRAPHQL=false
VITE_RECURRING_INVOICE_GENERATION_GRAPHQL=false
# Payment history and manual writes have independent rollback boundaries.
VITE_PAYMENT_READS_GRAPHQL=false
VITE_PAYMENT_MUTATIONS_GRAPHQL=false
# Authenticated onboarding reads and writes have separate rollback boundaries.
VITE_ONBOARDING_READS_GRAPHQL=false
VITE_ONBOARDING_MUTATIONS_GRAPHQL=false
# Workspace selector membership reads and selection/default-repair writes.
VITE_ORGANIZATION_READS_GRAPHQL=false
VITE_ORGANIZATION_MUTATIONS_GRAPHQL=false
# External connection reads/settings/disconnect/sync jobs. Google OAuth
# redirects and live provider-calendar discovery remain on the REST edge.
VITE_CALENDAR_INTEGRATIONS_GRAPHQL=false
# Personal list reads/writes and note reads/writes remain on REST unless
# independently enabled.
VITE_WORKSPACE_LIST_READS_GRAPHQL=false
VITE_WORKSPACE_LIST_MUTATIONS_GRAPHQL=false
VITE_WORKSPACE_NOTE_READS_GRAPHQL=false
VITE_WORKSPACE_NOTE_MUTATIONS_GRAPHQL=false
VITE_WORKSPACE_WHITEBOARD_READS_GRAPHQL=false
VITE_WORKSPACE_WHITEBOARD_MUTATIONS_GRAPHQL=false

# Development-only staging harness. This never bypasses cookie authentication;
# it only permits /api/auth/me to run without an existing browser-storage hint.
VITE_DEV_AUTH_PROBE_WITHOUT_HINT=false

# ---------- Google sign-in ----------
# Same client ID as backend GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ---------- Optional overrides (see src/lib/api.ts) ----------
# VITE_PRODUCTION_API_URL=https://api.your-domain.com
# VITE_PRODUCTION_DOMAIN=your-domain.com

# ---------- Error tracking ----------
# NEXT_PUBLIC-equivalent for Vite; enable in staging/production builds.
# VITE_SENTRY_DSN=https://xxx@o1234.ingest.sentry.io/1234

# =============================================
# Production checklist
# =============================================
# - VITE_API_URL points at the public HTTPS API (not localhost).
# - VITE_SENTRY_DSN set for browser error tracking.
# - OAuth origin / redirect URIs match the deployed SPA URL.

