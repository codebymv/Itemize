# =============================================
# Itemize backend — environment variables
# =============================================
# Copy to .env locally. Railway: set equivalents in dashboard.
#
# REQUIRED variables are enforced at startup via env-validation.js
# =============================================

# ---------- Core ----------
NODE_ENV=development
PORT=3001

# Frontend app URL — used for CORS, redirects, emails (required)
FRONTEND_URL=http://localhost:5173

# Extra browser origins allowed by CORS (comma-separated), e.g. staging frontends
# EXTRA_CORS_ORIGINS=https://staging.itemize.cloud,https://itemize-staging.up.railway.app

# Side-by-side NestJS GraphQL service. Prefer its Railway private-network URL.
# GRAPHQL_UPSTREAM_URL=http://itemize-cloud-graphql.railway.internal:3100/graphql
# GRAPHQL_UPSTREAM_TIMEOUT_MS=10000
# Retained contact CSV routes can independently proxy to the same NestJS service.
# Keep disabled until the staging import/export and rollback gate passes.
# CONTACT_TRANSFERS_NESTJS_ENABLED=false
# CONTACT_TRANSFERS_UPSTREAM_TIMEOUT_MS=30000
# INVOICE_PDF_NESTJS_ENABLED=false
# INVOICE_PDF_UPSTREAM_TIMEOUT_MS=60000
# STRIPE_INVOICE_WEBHOOK_NESTJS_ENABLED=false
# STRIPE_INVOICE_WEBHOOK_UPSTREAM_TIMEOUT_MS=30000

# ---------- Database (REQUIRED) ----------
DATABASE_URL=postgresql://username:password@localhost:5432/itemize

# ---------- Authentication (REQUIRED) ----------
# Minimum 32 characters in all environments.
JWT_SECRET=your_super_secret_jwt_key_here_min_32_characters__

# ---------- Google OAuth (optional; enable Google sign-in) ----------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Must exactly match a redirect URI registered on the Google OAuth client.
# Set this explicitly for staging so its authorization flow cannot reach production.
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/calendar-integrations/google/callback

# Required in production when Google OAuth is enabled. Values are 32-byte hex
# AES keys. Keep old entries during rotation so existing envelopes remain readable.
# Generate a key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_ACTIVE_KEY_ID=calendar-2026-01
CALENDAR_TOKEN_ENCRYPTION_KEYS={"calendar-2026-01":"replace_with_64_hex_characters"}

# Durable bidirectional calendar synchronization. Apply migration 033 before
# enabling this worker. Start with one replica and inspect sync-status results.
CALENDAR_SYNC_JOBS_ENABLED=false
CALENDAR_SYNC_JOB_BATCH_SIZE=10
CALENDAR_SYNC_JOB_LEASE_SECONDS=300
CALENDAR_SYNC_JOB_MAX_ATTEMPTS=5

# ---------- Cookies (production / cross-domain) ----------
# Optional: overrides auto-derived cookie domain from FRONTEND_URL
# COOKIE_DOMAIN=.itemize.cloud

# ---------- Observability ----------
# Recommended in production — https://sentry.io
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# Startup health grace (ms) — /api/health returns "starting" until DB connects
# HEALTHCHECK_STARTUP_GRACE_MS=60000

# ---------- Email (Resend) ----------
RESEND_API_KEY=your_resend_api_key
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_signing_secret
EMAIL_FROM=noreply@yourdomain.com

# ---------- SMS (Twilio) ----------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ---------- Workflow workers ----------
# Provider outbox delivery is enabled unless explicitly disabled.
WORKFLOW_SIDE_EFFECT_JOBS_ENABLED=true
# Outbound workflow webhooks never follow redirects, validate and pin public DNS
# answers, and cap both payload directions. Allowed range: 1 KiB to 1 MiB.
WORKFLOW_WEBHOOK_MAX_REQUEST_BYTES=262144
WORKFLOW_WEBHOOK_MAX_RESPONSE_BYTES=65536
# Trigger fan-out and enrollment execution require an intentional rollout.
WORKFLOW_TRIGGER_JOBS_ENABLED=false
WORKFLOW_ENROLLMENT_JOBS_ENABLED=false

# ---------- Cross-service realtime bridge ----------
# Keep disabled until migration 028 is applied and Nest mutations enqueue their
# Socket.IO side effects in the same transaction as each domain write.
REALTIME_OUTBOX_WORKER_ENABLED=false
# The current in-memory Socket.IO adapter requires exactly one enabled socket
# host. Do not enable this worker on multiple replicas without a shared adapter.
REALTIME_OUTBOX_POLL_INTERVAL_MS=500
REALTIME_OUTBOX_BATCH_SIZE=25
REALTIME_OUTBOX_LEASE_SECONDS=30
REALTIME_OUTBOX_MAX_ATTEMPTS=5

# ---------- Workflow staging rollout harness ----------
# Required marker for workflow:rollout:* commands. These commands reject known
# production deployment labels even when NODE_ENV=production in staging.
# WORKFLOW_ROLLOUT_ENVIRONMENT=staging
# Pin the exact host/port/database selected by DATABASE_URL. Generate without
# opening a database connection: npm run workflow:rollout:identity
# WORKFLOW_ROLLOUT_DATABASE_FINGERPRINT=
# Dedicated staging organization/operator and sandbox email recipient.
# WORKFLOW_CANARY_ORGANIZATION_ID=
# WORKFLOW_CANARY_CREATED_BY_USER_ID=
# WORKFLOW_CANARY_EMAIL=
# Operator assertion that RESEND_API_KEY/EMAIL_FROM are sandbox-only.
# WORKFLOW_CANARY_PROVIDER_MODE=sandbox
# Required only for `npm run workflow:rollout:canary`.
# WORKFLOW_CANARY_CONFIRM=I_CONFIRM_STAGING_SANDBOX_DELIVERY
# Preflight alert/block thresholds.
# WORKFLOW_ROLLOUT_MAX_PENDING_AGE_SECONDS=300
# WORKFLOW_ROLLOUT_MAX_DEAD_LETTERS=0
# WORKFLOW_ROLLOUT_MAX_RECONCILIATION_REQUIRED=0
# Optional JSON evidence directory; defaults to backend/.workflow-rollout-results.
# WORKFLOW_ROLLOUT_EVIDENCE_DIR=
# Drain requires all three worker flags above to be explicitly false.
# WORKFLOW_DRAIN_CONFIRM=I_CONFIRM_STAGING_DISABLE_AND_DRAIN
# WORKFLOW_DRAIN_BATCH_SIZE=100
# WORKFLOW_DRAIN_MAX_CYCLES=20

# Local-only: skip Twilio webhook signature checks. Forbidden in production (server exits at boot).
# SKIP_TWILIO_WEBHOOK_VALIDATION=true

# ---------- AI (Google Gemini; optional features) ----------
GEMINI_API_KEY=your_gemini_api_key

# ---------- Billing (Stripe) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Local-only: accept unsigned Stripe webhook bodies (e.g. manual testing). Forbidden in production.
# STRIPE_WEBHOOK_SKIP_VERIFY=true

# ---------- File storage (AWS S3) ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
AWS_S3_BUCKET=itemize-uploads

# ---------- PDF / Puppeteer ----------
# Windows local dev example:
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Railway/Linux: omit (bundled Chromium)

# =============================================
# Production checklist (before go-live)
# =============================================
#
# - NODE_ENV=production
# - DATABASE_URL points to managed Postgres
# - FRONTEND_URL=https://your-app-domain (not localhost)
# - JWT_SECRET is unique vs dev/staging (32+ chars)
# - SENTRY_DSN set for backend
# - STRIPE_WEBHOOK_SECRET matches Stripe Dashboard webhook signing secret
# - OAuth redirects (Google Console) use production URLs
# - Calendar OAuth token keyring is set; old keys remain until all envelopes rotate
# - CORS: localhost is allowed only outside production; prod uses FRONTEND_URL + pinned domains + EXTRA_CORS_ORIGINS if set

# Meta social webhook verification
FACEBOOK_APP_SECRET=replace-with-meta-app-secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=replace-with-random-verification-token
