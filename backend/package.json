{
  "name": "itemize-backend",
  "version": "1.0.0",
  "description": "Backend API for Itemize app",
  "main": "src/index.js",
  "scripts": {
    "start": "node --dns-result-order=ipv4first src/index.js",
    "dev": "nodemon --dns-result-order=ipv4first src/index.js",
    "migrate": "node scripts/execute-migration.js",
    "seed:templates": "node scripts/seed-all-templates.js",
    "seed:system-templates": "node scripts/seed-system-templates.js",
    "seed:broadcast-templates": "node scripts/seed-broadcast-templates.js",
    "build": "echo 'No build step required'",
    "lint": "node ../node_modules/eslint/bin/eslint.js .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration:config": "jest src/__tests__/utils/test-database-config.test.js --runInBand",
    "test:integration": "jest --testPathIgnorePatterns=\"/node_modules/|/dist/\" --testMatch=\"**/src/__tests__/integration/**/*.test.js\" --runInBand --testTimeout=60000 --globalSetup=./src/__tests__/integration/global-setup.js --globalTeardown=./src/__tests__/integration/global-teardown.js",
    "test:integration:fresh": "node scripts/run-integration-tests-fresh.js",
    "test:browser:shared-realtime": "node scripts/run-shared-realtime-browser-tests.mjs",
    "workflow:rollout:identity": "node scripts/workflow-rollout.js identity",
    "workflow:rollout:preflight": "node scripts/workflow-rollout.js preflight",
    "workflow:rollout:canary": "node scripts/workflow-rollout.js canary",
    "workflow:rollout:drain": "node scripts/workflow-rollout.js drain",
    "db:test:reset": "node scripts/initialize-test-database.js --reset --confirm-reset",
    "db:test:verify": "node scripts/initialize-test-database.js",
    "jobs:signature-file-cleanup": "node scripts/run-signature-file-cleanup.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.38.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.2.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "googleapis": "^170.1.0",
    "helmet": "^7.1.0",
    "ipaddr.js": "^1.9.1",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.36.0",
    "resend": "^6.8.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^20.2.0",
    "twilio": "^5.4.0",
    "uuid": "^8.3.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
