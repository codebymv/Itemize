# Integration tests never fall back to DATABASE_URL.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/itemize_test

# Local PostgreSQL normally does not use TLS. Set this to true for a hosted test database.
TEST_DATABASE_SSL=false
TEST_DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Required only when neither the database name nor host visibly contains test/ci/integration.
# This does not bypass a TEST_DATABASE_URL that is identical to DATABASE_URL.
# TEST_DATABASE_CONFIRM_ISOLATED=I_CONFIRM_THIS_DATABASE_IS_DISPOSABLE

JWT_SECRET=test-jwt-secret-for-integration-tests-only

# Calendar token encryption derives an isolated key from JWT_SECRET in test mode.
# Set these only when explicitly testing a production-style multi-key rotation.
# CALENDAR_TOKEN_ACTIVE_KEY_ID=test-v2
# CALENDAR_TOKEN_ENCRYPTION_KEYS={"test-v1":"<64 hex>","test-v2":"<64 hex>"}

# From backend/:
#   npm run db:test:reset       # destructive; rebuilds only the validated TEST_DATABASE_URL
#   npm run db:test:verify      # non-destructive schema verification
#   npm run test:integration
# Or use npm run test:integration:fresh to create/run/destroy PostgreSQL with Docker.
